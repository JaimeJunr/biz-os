{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)"
    ],
    "deny": []
  },
  "extraKnownMarketplaces": {
    "marketingskills": {
      "source": { "source": "github", "repo": "coreyhaines31/marketingskills" }
    },
    "anthropic-agent-skills": {
      "source": { "source": "github", "repo": "anthropics/skills" }
    },
    "claude-plugins-official": {
      "source": { "source": "github", "repo": "anthropics/claude-plugins-official" }
    },
    "ui-ux-pro-max-skill": {
      "source": { "source": "github", "repo": "nextlevelbuilder/ui-ux-pro-max-skill" }
    },
    "openclaudia-skills": {
      "source": { "source": "github", "repo": "OpenClaudia/openclaudia-skills" }
    },
    "ai-marketing-claude-code-skills": {
      "source": { "source": "github", "repo": "BrianRWagner/ai-marketing-claude-code-skills" }
    }
  },
  "enabledPlugins": {
    "marketing-skills@marketingskills": true,
    "document-skills@anthropic-agent-skills": true,
    "brand-guidelines@anthropic-agent-skills": true,
    "skill-creator@anthropic-agent-skills": true,
    "mcp-builder@anthropic-agent-skills": true,
    "frontend-design@anthropic-agent-skills": true,
    "design@claude-plugins-official": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true
  },
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ]
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "."
      ]
    },
    "google-sheets": {
      "command": "npx",
      "args": [
        "-y",
        "@mkusaka/mcp-server-google-sheets"
      ],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "${HOME}/.config/biz-os/google-credentials.json"
      },
      "_comment": "Substitua pelo MCP de Sheets de sua preferencia. Veja https://github.com/modelcontextprotocol/servers"
    },
    "meta-ads": {
      "command": "npx",
      "args": [
        "-y",
        "meta-ads-mcp"
      ],
      "env": {
        "META_ACCESS_TOKEN": "${META_ACCESS_TOKEN}",
        "META_AD_ACCOUNT_ID": "${META_AD_ACCOUNT_ID}"
      },
      "_comment": "Pacote da comunidade. Configure token em ~/.config/biz-os/.env e exporte via direnv."
    },
    "notion": {
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\":\"Bearer ${NOTION_TOKEN}\",\"Notion-Version\":\"2022-06-28\"}"
      }
    }
  }
}
