{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)"
    ],
    "deny": []
  },
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ]
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "."
      ]
    },
    "google-sheets": {
      "command": "npx",
      "args": [
        "-y",
        "@mkusaka/mcp-server-google-sheets"
      ],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "${HOME}/.config/biz-os/google-credentials.json"
      },
      "_comment": "Substitua pelo MCP de Sheets de sua preferencia. Veja https://github.com/modelcontextprotocol/servers"
    },
    "meta-ads": {
      "command": "npx",
      "args": [
        "-y",
        "meta-ads-mcp"
      ],
      "env": {
        "META_ACCESS_TOKEN": "${META_ACCESS_TOKEN}",
        "META_AD_ACCOUNT_ID": "${META_AD_ACCOUNT_ID}"
      },
      "_comment": "Pacote da comunidade. Configure token em ~/.config/biz-os/.env e exporte via direnv."
    },
    "notion": {
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\":\"Bearer ${NOTION_TOKEN}\",\"Notion-Version\":\"2022-06-28\"}"
      }
    }
  },
  "_skills": {
    "_comment": "Skills sao instaladas via /plugin marketplace e /plugin install. Lista abaixo eh referencia. Rode bin/setup.sh na raiz do biz-os para instalar tudo de uma vez.",
    "base_marketing": [
      "coreyhaines31/marketingskills :: PLUGIN BASE — 40 skills, le .agents/product-marketing.md"
    ],
    "oficiais_anthropic": [
      "anthropics/skills :: document-skills (docx, xlsx, pptx, pdf)",
      "anthropics/skills :: brand-guidelines",
      "anthropics/skills :: skill-creator",
      "anthropics/skills :: mcp-builder",
      "anthropics/skills :: doc-coauthoring",
      "anthropics/skills :: internal-comms"
    ],
    "design_stack": [
      "anthropics/claude-plugins-official :: design (critique, ux-writing, a11y, research, dev handoff)",
      "anthropics/skills :: frontend-design (760k+ installs)",
      "nextlevelbuilder/ui-ux-pro-max-skill (81k+ stars, 161 reasoning rules, 67 UI styles)"
    ],
    "comunidade_complementar": [
      "OpenClaudia/openclaudia-skills",
      "BrianRWagner/ai-marketing-claude-code-skills"
    ]
  }
}
